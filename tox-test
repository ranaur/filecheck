#!/usr/bin/env bash
set -euo pipefail

PYENV_ROOT="${PYENV_ROOT:-$HOME/.pyenv}"
VERSIONS_DIR="$PYENV_ROOT/versions"

if [ ! -d "$VERSIONS_DIR" ]; then
    echo "ERROR: $VERSIONS_DIR not found. Is pyenv installed?" >&2
    exit 1
fi

declare -A PATCH_VERSIONS

for dir in "$VERSIONS_DIR"/3.*; do
    dirname=$(basename "$dir")
    if [[ "$dirname" =~ ^3\.([0-9]+)\.([0-9]+)$ ]]; then
        minor="${BASH_REMATCH[1]}"
        patch="${BASH_REMATCH[2]}"
        key="3.$minor"
        if [ -z "${PATCH_VERSIONS[$key]:-}" ] || [ "$patch" -gt "${PATCH_VERSIONS[$key]}" ]; then
            PATCH_VERSIONS[$key]="$patch"
        fi
    fi
done

if [ ${#PATCH_VERSIONS[@]} -eq 0 ]; then
    echo "ERROR: No Python 3.x.y versions found in $VERSIONS_DIR" >&2
    exit 1
fi

for key in "${!PATCH_VERSIONS[@]}"; do
    patch="${PATCH_VERSIONS[$key]}"
    version="$key.$patch"
    bin_dir="$VERSIONS_DIR/$version/bin"
    if [ -d "$bin_dir" ]; then
        export PATH="$bin_dir:$PATH"
    fi
done

exec tox "$@"
